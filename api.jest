use web

print("Starting Jestlang API")

app = web

fn home():
    return {
        message: "Jestlang Online",
        status: "running"
    }

fn user():
    return {
        id: params.id,
        name: "Lucas",
        language: "Jestlang"
    }

fn login():
    return {
        success: true,
        token: "jest_123"
    }

app.get("/", home)

app.get("/users/:id", user)

app.post("/login", login)

app.run(3000)